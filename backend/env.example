# ggNet Backend Configuration
# Copy this file to .env and customize as needed

# Application
APP_NAME=ggNet
HOST=0.0.0.0
PORT=5000
DEBUG=True

# Database (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./ggnet.db

# Storage paths (will be created automatically)
STATIC_ROOT=./storage
IMAGE_ROOT=./storage/images
WRITEBACK_ROOT=./storage/writebacks
SNAPSHOT_ROOT=./storage/snapshots
TFTP_ROOT=./pxe/tftp
NFS_ROOT=./storage/nfs

# Cache limit (in MB)
CACHE_LIMIT_MB=51200

