################################################################################
# ggNet Backend - Production Configuration
#
# Copy this file to .env and configure for your production environment
#
################################################################################

# Application Settings
APP_NAME=ggNet
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database Settings
DATABASE_URL=postgresql://ggnet:ggnet_secure_password@localhost:5432/ggnet
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Security Settings
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# Logging Settings
LOG_LEVEL=INFO
LOG_DIR=/var/log/ggnet
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Monitoring Settings
METRICS_ENABLED=true
METRICS_COLLECTION_INTERVAL=60
METRICS_HISTORY_SIZE=1000

# Core Services Settings
DHCP_ENABLED=true
DHCP_INTERFACE=eth0
DHCP_SERVER_IP=192.168.1.1
DHCP_START=192.168.1.100
DHCP_END=192.168.1.200
DHCP_SUBNET_MASK=255.255.255.0
DHCP_GATEWAY=192.168.1.1
DHCP_DNS_SERVERS=["8.8.8.8","8.8.4.4"]
DHCP_TFTP_SERVER=192.168.1.1
DHCP_ENABLE_PXE=true

TFTP_ENABLED=true
TFTP_ROOT_DIR=/var/lib/tftpboot
TFTP_LISTEN_ADDRESS=0.0.0.0
TFTP_PORT=69

NFS_ENABLED=true
NFS_ROOT_DIR=/srv/nfs/ggnet
NFS_NETWORK=192.168.1.0/24
NFS_OPTIONS=rw,sync,no_subtree_check,no_root_squash

PXE_ENABLED=true
PXE_TFTP_ROOT=/var/lib/tftpboot
PXE_BOOT_FILE=pxelinux.0

# Storage Settings
STORAGE_PATH=/var/lib/ggnet
IMAGES_PATH=/var/lib/ggnet/images
WRITEBACKS_PATH=/var/lib/ggnet/writebacks
SNAPSHOTS_PATH=/var/lib/ggnet/snapshots

# ZFS Settings (if using ZFS)
ZFS_ENABLED=true
ZFS_POOL=ggnet-pool
ZFS_DATASET=ggnet-data

# Cache Settings
CACHE_ENABLED=true
CACHE_MAX_SIZE=536870912
CACHE_TTL=3600

# Session Settings
SESSION_TIMEOUT=1800
MAX_SESSIONS=100

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/var/backups/ggnet

# Email Settings (for alerts)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@ggnet.local
SMTP_TO=admin@example.com

# Webhook Settings (for alerts)
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Performance Settings
MAX_WORKERS=4
WORKER_TIMEOUT=120
KEEPALIVE_TIMEOUT=5

# Feature Flags
FEATURE_PXE_BOOT=true
FEATURE_WRITEBACK=true
FEATURE_SNAPSHOTS=true
FEATURE_MONITORING=true
FEATURE_ALERTS=true

