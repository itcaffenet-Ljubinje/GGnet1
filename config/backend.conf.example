# ggNet Backend Configuration
# Copy to /etc/ggnet/backend.conf and customize

# Server
PORT=5000
NODE_ENV=production

# Frontend
FRONTEND_URL=http://localhost

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ggnet
DB_USER=ggnet
DB_PASSWORD=change_this_password

# Security
JWT_SECRET=change_this_secret_key_min_32_chars
SESSION_SECRET=change_this_session_secret

# ZFS
ZFS_POOL=pool0
ZFS_IMAGES_PATH=/pool0/ggnet/images
ZFS_BACKUPS_PATH=/pool0/ggnet/backups

# Array
ARRAY_DEVICE_PREFIX=/dev/sd
ARRAY_MOUNT_POINT=/mnt/ggnet

# Secure Boot
SECURE_BOOT_KEYS_PATH=/etc/ggnet/secure-boot/keys
SECURE_BOOT_BOOT_FILES_PATH=/var/lib/tftpboot/ggnet

# PXE Boot
TFTP_ROOT=/var/lib/tftpboot
PXE_CONFIG_PATH=/var/lib/tftpboot/pxelinux.cfg

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/ggnet/backend.log

# Features
ENABLE_AUTO_ENROLLMENT=true
ENABLE_SNAPSHOTS_CLEANUP=true
ENABLE_TRIM=true

